[Unit]
Description=Whatsapp Bot App
After=network.target
Wants=mongod.service

[Service]
Type=simple
Restart=always
WorkingDirectory=/home/ubuntu/app/wa-bot/whatsapp-bot-multi-device
ExecStart=/home/ubuntu/app/wa-bot/whatsapp-bot-multi-device/start-app.sh
Environment=NODE_ENV=production
KillMode=control-group
TimeoutStopSec=10s

[Install]
WantedBy=multi-user.target